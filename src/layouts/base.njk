<!doctype html>
<html lang="en">
  <head>
    <title>{% getTitle title %}</title>
    {% include "metaTags.njk" %}
    <link rel="stylesheet" href="/styles/tailwind.css?ver={% getTimestamp %}">
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    {% include "nav.njk" %}
    <main id="main" class="container mx-auto">
      {{ content | safe }}
    </main>
    {% include "footer.njk" %}
    <script type="module" src="/scripts/webamp-init.js?ver={% getTimestamp %}"></script>
  </body>
</html>
