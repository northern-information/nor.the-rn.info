{%- set ogImage = null -%}
{%- if release -%}
  {%- set ogImage = release.cover_url -%}
{%- elif project -%}
  {%- set ogImage = project.image -%}
{%- elif content -%}
  {%- set ogImage = content | extractFirstImage -%}
{%- endif -%}
{%- if ogImage -%}
  {{- ogImage | toAbsoluteUrl(site.META.DOMAIN) -}}
{%- else -%}
  {{- site.META.LOGO | toAbsoluteUrl(site.META.CANONICAL) -}}
{%- endif -%}
