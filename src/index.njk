---
layout: base.njk
title: Northern Information
---
{# Featured Project - Full Width #}
{% set featured = projectGroups.featured[0] %}

{% if featured %}
  <section class="mb-1 border-t-4 border-solid border-black" aria-label="Featured project">
    <a href="/project/{{ featured.slug }}/" class="group block">
      <div class="grain relative aspect-square w-full overflow-hidden md:aspect-21/9">
        <img
          src="{{ featured.image }}"
          alt="{{ featured.name }}"
          class="z-0 h-full w-full object-cover object-top group-hover:invert"
        >
        <div class="burn pointer-events-none absolute inset-0 z-10"></div>
        <div class="absolute right-0 bottom-0 left-0 z-20 p-2">
          <span class="font-mono text-sm text-yellow-300">{{ featured.dateRange }}</span>
          <h2 class="text-2xl font-bold text-white group-hover:underline md:text-4xl">{{ featured.name }}</h2>
        </div>
      </div>
    </a>
  </section>
{% endif %}

{# Active Projects - 3-column Grid (excluding featured) #}
{% set activeNotFeatured = projectGroups.activeNotFeatured %}

{% if activeNotFeatured.length > 0 %}
  <section class="mb-1" aria-label="Active projects">
    <ul class="grid-projects">
      {% for project in activeNotFeatured %}
        <li class="group">
          <a href="/project/{{ project.slug }}/" class="block cursor-pointer">
            <div class="grain relative aspect-square w-full overflow-hidden">
              <img
                src="{{ project.image }}"
                alt="{{ project.name }}"
                class="z-0 h-full w-full object-cover object-top{% if not project.hoverImage %} group-hover:invert{% else %} group-hover:opacity-0{% endif %}"
                loading="lazy"
              >
              {% if project.hoverImage %}
                <img
                  src="{{ project.hoverImage }}"
                  alt="{{ project.name }}"
                  class="absolute inset-0 z-0 h-full w-full object-cover object-top opacity-0 group-hover:opacity-100"
                  loading="lazy"
                >
              {% endif %}
              <div class="burn pointer-events-none absolute inset-0 z-10"></div>
              <div class="absolute right-0 bottom-0 left-0 z-20 p-2">
                <span class="font-mono text-sm text-yellow-300">{{ project.dateRange }}</span>
                <h3 class="w-full truncate font-bold text-white group-hover:underline">{{ project.name }}</h3>
              </div>
            </div>
          </a>
        </li>
      {% endfor %}
    </ul>
  </section>
{% endif %}
